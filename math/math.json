[
  {"id":"m001","name":"加法交换律","formula":"a + b = b + a","desc":"两个数相加，交换加数的位置，和不变","example":"3 + 5 = 5 + 3 = 8","category":"运算律","scope":["小学"],"difficulty":1},
  {"id":"m002","name":"乘法交换律","formula":"a × b = b × a","desc":"两个数相乘，交换因数的位置，积不变","example":"4 × 7 = 7 × 4 = 28","category":"运算律","scope":["小学"],"difficulty":1},
  {"id":"m003","name":"加法结合律","formula":"(a + b) + c = a + (b + c)","desc":"三个数相加，先把前两个数相加或先把后两个数相加，和不变","example":"(2+3)+4 = 2+(3+4) = 9","category":"运算律","scope":["小学"],"difficulty":1},
  {"id":"m004","name":"乘法结合律","formula":"(a × b) × c = a × (b × c)","desc":"三个数相乘，先把前两个数相乘或先把后两个数相乘，积不变","example":"(2×3)×4 = 2×(3×4) = 24","category":"运算律","scope":["小学"],"difficulty":1},
  {"id":"m005","name":"乘法分配律","formula":"a × (b + c) = a × b + a × c","desc":"一个数与两个数的和相乘，等于把这个数分别与这两个数相乘再相加","example":"3×(4+5) = 3×4+3×5 = 27","category":"运算律","scope":["小学"],"difficulty":2},
  {"id":"m006","name":"长方形面积","formula":"S = a × b","desc":"长方形面积等于长乘以宽","example":"长5宽3的长方形，面积=5×3=15","category":"几何公式","scope":["小学"],"difficulty":1},
  {"id":"m007","name":"长方形周长","formula":"C = 2(a + b)","desc":"长方形周长等于两倍的长加宽","example":"长5宽3的长方形，周长=2×(5+3)=16","category":"几何公式","scope":["小学"],"difficulty":1},
  {"id":"m008","name":"正方形面积","formula":"S = a²","desc":"正方形面积等于边长的平方","example":"边长4的正方形，面积=4²=16","category":"几何公式","scope":["小学"],"difficulty":1},
  {"id":"m009","name":"正方形周长","formula":"C = 4a","desc":"正方形周长等于边长的4倍","example":"边长4的正方形，周长=4×4=16","category":"几何公式","scope":["小学"],"difficulty":1},
  {"id":"m010","name":"三角形面积","formula":"S = ½ah","desc":"三角形面积等于底乘以高除以2","example":"底6高4的三角形，面积=6×4÷2=12","category":"几何公式","scope":["小学"],"difficulty":2},
  {"id":"m011","name":"平行四边形面积","formula":"S = ah","desc":"平行四边形面积等于底乘以高","example":"底5高3的平行四边形，面积=5×3=15","category":"几何公式","scope":["小学"],"difficulty":2},
  {"id":"m012","name":"梯形面积","formula":"S = ½(a + b)h","desc":"梯形面积等于上底加下底的和乘以高除以2","example":"上底3下底5高4的梯形，面积=(3+5)×4÷2=16","category":"几何公式","scope":["小学"],"difficulty":2},
  {"id":"m013","name":"圆的面积","formula":"S = πr²","desc":"圆的面积等于π乘以半径的平方","example":"半径3的圆，面积=π×9≈28.27","category":"几何公式","scope":["小学"],"difficulty":3},
  {"id":"m014","name":"圆的周长","formula":"C = 2πr","desc":"圆的周长等于2π乘以半径","example":"半径3的圆，周长=2π×3≈18.85","category":"几何公式","scope":["小学"],"difficulty":3},
  {"id":"m015","name":"圆环面积","formula":"S = π(R² - r²)","desc":"圆环面积等于大圆面积减小圆面积","example":"大圆半径5小圆半径3，面积=π(25-9)≈50.27","category":"几何公式","scope":["小学"],"difficulty":3},
  {"id":"m016","name":"长方体体积","formula":"V = abh","desc":"长方体体积等于长乘以宽乘以高","example":"长5宽3高2，体积=5×3×2=30","category":"几何公式","scope":["小学"],"difficulty":2},
  {"id":"m017","name":"正方体体积","formula":"V = a³","desc":"正方体体积等于边长的立方","example":"边长3的正方体，体积=3³=27","category":"几何公式","scope":["小学"],"difficulty":2},
  {"id":"m018","name":"长方体表面积","formula":"S = 2(ab + ah + bh)","desc":"长方体表面积等于六个面的面积之和","example":"长5宽3高2，表面积=2(15+10+6)=62","category":"几何公式","scope":["小学"],"difficulty":3},
  {"id":"m019","name":"正方体表面积","formula":"S = 6a²","desc":"正方体表面积等于6个面的面积之和","example":"边长3的正方体，表面积=6×9=54","category":"几何公式","scope":["小学"],"difficulty":2},
  {"id":"m020","name":"分数加减法","formula":"a/b ± c/b = (a±c)/b","desc":"同分母分数相加减，分母不变，分子相加减","example":"1/5 + 2/5 = 3/5","category":"分数运算","scope":["小学"],"difficulty":2},
  {"id":"m021","name":"异分母分数加减","formula":"a/b ± c/d = (ad±bc)/bd","desc":"异分母分数相加减，先通分再加减","example":"1/2 + 1/3 = 3/6 + 2/6 = 5/6","category":"分数运算","scope":["小学"],"difficulty":3},
  {"id":"m022","name":"分数乘法","formula":"a/b × c/d = ac/bd","desc":"分数乘分数，分子乘分子，分母乘分母","example":"2/3 × 3/4 = 6/12 = 1/2","category":"分数运算","scope":["小学"],"difficulty":2},
  {"id":"m023","name":"分数除法","formula":"a/b ÷ c/d = a/b × d/c = ad/bc","desc":"分数除以分数，等于乘以除数的倒数","example":"2/3 ÷ 4/5 = 2/3 × 5/4 = 10/12 = 5/6","category":"分数运算","scope":["小学"],"difficulty":3},
  {"id":"m024","name":"百分数化小数","formula":"百分数÷100=小数","desc":"百分数去掉百分号，小数点左移两位","example":"25% = 0.25","category":"数与代数","scope":["小学"],"difficulty":1},
  {"id":"m025","name":"利润率","formula":"利润率 = 利润 ÷ 成本 × 100%","desc":"利润占成本的百分比","example":"成本100元售价130元，利润率=30÷100×100%=30%","category":"数与代数","scope":["小学"],"difficulty":3},
  {"id":"m026","name":"相遇问题","formula":"相遇时间 = 总路程 ÷ 速度和","desc":"两人相向而行，相遇时间等于总路程除以速度之和","example":"甲乙相距300km，甲速60乙速40，相遇时间=300÷100=3小时","category":"应用公式","scope":["小学"],"difficulty":3},
  {"id":"m027","name":"追及问题","formula":"追及时间 = 路程差 ÷ 速度差","desc":"两人同向而行，追及时间等于路程差除以速度差","example":"甲在前60km，乙速80甲速60，追及时间=60÷20=3小时","category":"应用公式","scope":["小学"],"difficulty":3},
  {"id":"m028","name":"工程问题","formula":"合作时间 = 1 ÷ (1/a + 1/b)","desc":"两人合作完成工程的时间","example":"甲独做6天乙独做3天，合作=1÷(1/6+1/3)=2天","category":"应用公式","scope":["小学"],"difficulty":3},
  {"id":"m029","name":"乘法分配律逆用","formula":"a × b + a × c = a × (b + c)","desc":"提取公因数，逆用乘法分配律","example":"3×7+3×3 = 3×(7+3) = 30","category":"运算律","scope":["小学"],"difficulty":2},
  {"id":"m030","name":"平均数","formula":"平均数 = 总数 ÷ 个数","desc":"所有数据的和除以数据个数","example":"85+90+95的平均数=270÷3=90","category":"统计","scope":["小学"],"difficulty":1},

  {"id":"m031","name":"幂的运算法则","formula":"aᵐ × aⁿ = aᵐ⁺ⁿ","desc":"同底数幂相乘，底数不变，指数相加","example":"2³ × 2⁴ = 2⁷ = 128","category":"幂运算","scope":["初中"],"difficulty":2},
  {"id":"m032","name":"幂的乘方","formula":"(aᵐ)ⁿ = aᵐⁿ","desc":"幂的乘方，底数不变，指数相乘","example":"(2³)² = 2⁶ = 64","category":"幂运算","scope":["初中"],"difficulty":2},
  {"id":"m033","name":"积的乘方","formula":"(ab)ⁿ = aⁿbⁿ","desc":"积的乘方等于各因数乘方的积","example":"(2×3)² = 2²×3² = 36","category":"幂运算","scope":["初中"],"difficulty":2},
  {"id":"m034","name":"同底数幂除法","formula":"aᵐ ÷ aⁿ = aᵐ⁻ⁿ (a≠0, m>n)","desc":"同底数幂相除，底数不变，指数相减","example":"2⁵ ÷ 2³ = 2² = 4","category":"幂运算","scope":["初中"],"difficulty":2},
  {"id":"m035","name":"零指数幂","formula":"a⁰ = 1 (a≠0)","desc":"任何非零数的零次幂等于1","example":"5⁰ = 1","category":"幂运算","scope":["初中"],"difficulty":1},
  {"id":"m036","name":"负整数指数幂","formula":"a⁻ⁿ = 1/aⁿ (a≠0)","desc":"负整数指数幂等于正整数指数幂的倒数","example":"2⁻³ = 1/2³ = 1/8","category":"幂运算","scope":["初中"],"difficulty":2},
  {"id":"m037","name":"平方差公式","formula":"(a+b)(a-b) = a²-b²","desc":"两个数的和与这两个数的差的积等于这两个数的平方差","example":"(x+3)(x-3) = x²-9","category":"乘法公式","scope":["初中"],"difficulty":3},
  {"id":"m038","name":"完全平方公式","formula":"(a±b)² = a²±2ab+b²","desc":"两数和（差）的平方等于它们的平方和加（减）两倍乘积","example":"(x+2)² = x²+4x+4","category":"乘法公式","scope":["初中"],"difficulty":3},
  {"id":"m039","name":"一元二次方程求根公式","formula":"x = (-b ± √(b²-4ac)) / 2a","desc":"ax²+bx+c=0 (a≠0) 的根","example":"x²-5x+6=0，x=(5±1)/2，x₁=3, x₂=2","category":"方程","scope":["初中"],"difficulty":4},
  {"id":"m040","name":"判别式","formula":"Δ = b²-4ac","desc":"一元二次方程根的判别式，Δ>0两不等实根，Δ=0两等实根，Δ<0无实根","example":"x²-5x+6=0，Δ=25-24=1>0，有两个不等实根","category":"方程","scope":["初中"],"difficulty":3},
  {"id":"m041","name":"韦达定理","formula":"x₁+x₂=-b/a, x₁x₂=c/a","desc":"一元二次方程两根之和与两根之积与系数的关系","example":"x²-5x+6=0，x₁+x₂=5, x₁x₂=6","category":"方程","scope":["初中"],"difficulty":4},
  {"id":"m042","name":"勾股定理","formula":"a² + b² = c²","desc":"直角三角形中，两直角边的平方和等于斜边的平方","example":"直角边3和4，斜边=√(9+16)=5","category":"几何定理","scope":["初中"],"difficulty":2},
  {"id":"m043","name":"勾股定理逆定理","formula":"若a²+b²=c²，则△ABC为直角三角形","desc":"如果三角形三边满足两短边平方和等于最长边平方，则为直角三角形","example":"三边3,4,5满足9+16=25，是直角三角形","category":"几何定理","scope":["初中"],"difficulty":3},
  {"id":"m044","name":"三角形内角和","formula":"∠A+∠B+∠C = 180°","desc":"三角形三个内角的和等于180度","example":"已知两角50°和60°，第三角=180°-110°=70°","category":"几何定理","scope":["初中"],"difficulty":1},
  {"id":"m045","name":"三角形面积（坐标）","formula":"S = ½|x₁(y₂-y₃)+x₂(y₃-y₁)+x₃(y₁-y₂)|","desc":"已知三角形三顶点坐标求面积","example":"A(0,0),B(3,0),C(0,4)，S=½|0+0+12|=6","category":"几何公式","scope":["初中"],"difficulty":4},
  {"id":"m046","name":"弧长公式","formula":"l = nπr/180","desc":"圆心角为n°的弧长","example":"半径6圆心角60°，弧长=60×π×6/180=2π","category":"几何公式","scope":["初中"],"difficulty":3},
  {"id":"m047","name":"扇形面积公式","formula":"S = nπr²/360","desc":"圆心角为n°的扇形面积","example":"半径6圆心角60°，面积=60×π×36/360=6π","category":"几何公式","scope":["初中"],"difficulty":3},
  {"id":"m048","name":"圆的切线判定","formula":"经过半径外端且垂直于半径的直线是圆的切线","desc":"切线垂直于过切点的半径","example":"圆心O到直线l的距离等于半径，则l是切线","category":"几何定理","scope":["初中"],"difficulty":3},
  {"id":"m049","name":"相似三角形面积比","formula":"S₁/S₂ = (a₁/a₂)²","desc":"相似三角形面积比等于相似比的平方","example":"相似比2:3，面积比=4:9","category":"几何定理","scope":["初中"],"difficulty":3},
  {"id":"m050","name":"相似三角形对应比","formula":"对应边之比=对应高之比=对应周长之比=相似比","desc":"相似三角形所有对应线段之比等于相似比","example":"相似比3:5，对应高之比=3:5，周长比=3:5","category":"几何定理","scope":["初中"],"difficulty":3},
  {"id":"m051","name":"一次函数","formula":"y = kx + b (k≠0)","desc":"k为斜率，b为截距。k>0递增，k<0递减","example":"y=2x+1，斜率2，y轴截距1","category":"函数","scope":["初中"],"difficulty":2},
  {"id":"m052","name":"正比例函数","formula":"y = kx (k≠0)","desc":"过原点的直线，k为斜率","example":"y=3x，过原点斜率3","category":"函数","scope":["初中"],"difficulty":1},
  {"id":"m053","name":"反比例函数","formula":"y = k/x (k≠0)","desc":"图像为双曲线，过一三象限(k>0)或二四象限(k<0)","example":"y=6/x，过(1,6)(2,3)(3,2)","category":"函数","scope":["初中"],"difficulty":2},
  {"id":"m054","name":"二次函数","formula":"y = ax²+bx+c (a≠0)","desc":"图像为抛物线，a>0开口向上，a<0开口向下","example":"y=x²-2x+1=(x-1)²，顶点(1,0)","category":"函数","scope":["初中"],"difficulty":3},
  {"id":"m055","name":"二次函数顶点式","formula":"y = a(x-h)²+k","desc":"顶点坐标为(h,k)，a决定开口方向和大小","example":"y=2(x-3)²+1，顶点(3,1)","category":"函数","scope":["初中"],"difficulty":3},
  {"id":"m056","name":"二次函数顶点坐标","formula":"(-b/2a, (4ac-b²)/4a)","desc":"一般式y=ax²+bx+c的顶点坐标","example":"y=x²-4x+3，顶点(2,-1)","category":"函数","scope":["初中"],"difficulty":4},
  {"id":"m057","name":"中点公式","formula":"M = ((x₁+x₂)/2, (y₁+y₂)/2)","desc":"两点中点坐标公式","example":"A(2,4)和B(6,8)的中点M(4,6)","category":"坐标公式","scope":["初中"],"difficulty":2},
  {"id":"m058","name":"两点间距离公式","formula":"d = √((x₂-x₁)²+(y₂-y₁)²)","desc":"平面直角坐标系中两点间距离","example":"A(1,2)和B(4,6)，d=√(9+16)=5","category":"坐标公式","scope":["初中"],"difficulty":3},
  {"id":"m059","name":"平行四边形判定","formula":"两组对边分别平行/相等，或对角线互相平分","desc":"满足任一条件即为平行四边形","example":"四边形ABCD中AB∥CD, AD∥BC，是平行四边形","category":"几何定理","scope":["初中"],"difficulty":3},
  {"id":"m060","name":"全等三角形判定","formula":"SSS/SAS/ASA/AAS/HL","desc":"边边边、边角边、角边角、角角边、直角边斜边","example":"AB=DE, BC=EF, ∠B=∠E → SAS全等","category":"几何定理","scope":["初中"],"difficulty":3},

  {"id":"m061","name":"任意角三角函数定义","formula":"sinα=y/r, cosα=x/r, tanα=y/x","desc":"角α终边上点P(x,y)，r=√(x²+y²)","example":"P(3,4)，r=5，sinα=4/5, cosα=3/5, tanα=4/3","category":"三角函数","scope":["高中"],"difficulty":2},
  {"id":"m062","name":"同角三角函数关系","formula":"sin²α+cos²α=1, tanα=sinα/cosα","desc":"平方关系和商数关系","example":"sinα=3/5，cosα=4/5，验证：9/25+16/25=1","category":"三角函数","scope":["高中"],"difficulty":3},
  {"id":"m063","name":"正弦定理","formula":"a/sinA = b/sinB = c/sinC = 2R","desc":"三角形中各边与对角正弦之比相等，R为外接圆半径","example":"a=5,∠A=30°，2R=5/sin30°=10，R=5","category":"三角函数","scope":["高中"],"difficulty":4},
  {"id":"m064","name":"余弦定理","formula":"a²=b²+c²-2bc·cosA","desc":"三角形中一边的平方等于另两边平方和减去两倍乘积乘以夹角余弦","example":"b=3,c=5,∠A=60°，a²=9+25-2×3×5×0.5=19","category":"三角函数","scope":["高中"],"difficulty":4},
  {"id":"m065","name":"两角和差正弦","formula":"sin(α±β)=sinαcosβ±cosαsinβ","desc":"两角和差的正弦公式","example":"sin75°=sin(45°+30°)=sin45°cos30°+cos45°sin30°","category":"三角函数","scope":["高中"],"difficulty":4},
  {"id":"m066","name":"两角和差余弦","formula":"cos(α±β)=cosαcosβ∓sinαsinβ","desc":"两角和差的余弦公式","example":"cos15°=cos(45°-30°)=cos45°cos30°+sin45°sin30°","category":"三角函数","scope":["高中"],"difficulty":4},
  {"id":"m067","name":"二倍角公式","formula":"sin2α=2sinαcosα, cos2α=cos²α-sin²α","desc":"二倍角的正弦和余弦公式","example":"sin60°=2sin30°cos30°=2×0.5×(√3/2)=√3/2","category":"三角函数","scope":["高中"],"difficulty":4},
  {"id":"m068","name":"等差数列通项","formula":"aₙ = a₁ + (n-1)d","desc":"等差数列第n项等于首项加(n-1)乘以公差","example":"a₁=2,d=3，a₁₀=2+9×3=29","category":"数列","scope":["高中"],"difficulty":2},
  {"id":"m069","name":"等差数列前n项和","formula":"Sₙ = n(a₁+aₙ)/2 = na₁+n(n-1)d/2","desc":"等差数列前n项和公式","example":"a₁=1,d=2，S₁₀=10(1+19)/2=100","category":"数列","scope":["高中"],"difficulty":3},
  {"id":"m070","name":"等比数列通项","formula":"aₙ = a₁·qⁿ⁻¹","desc":"等比数列第n项等于首项乘以公比的(n-1)次方","example":"a₁=2,q=3，a₄=2×3³=54","category":"数列","scope":["高中"],"difficulty":2},
  {"id":"m071","name":"等比数列前n项和","formula":"Sₙ = a₁(1-qⁿ)/(1-q) (q≠1)","desc":"等比数列前n项和公式","example":"a₁=1,q=2，S₅=(1-32)/(1-2)=31","category":"数列","scope":["高中"],"difficulty":3},
  {"id":"m072","name":"导数定义","formula":"f'(x) = lim(Δx→0) [f(x+Δx)-f(x)]/Δx","desc":"函数在某点的瞬时变化率","example":"f(x)=x²，f'(x)=lim(2xΔx+Δx²)/Δx=2x","category":"导数","scope":["高中"],"difficulty":4},
  {"id":"m073","name":"常见导数-幂函数","formula":"(xⁿ)' = nxⁿ⁻¹","desc":"幂函数的导数公式","example":"(x³)' = 3x²","category":"导数","scope":["高中"],"difficulty":3},
  {"id":"m074","name":"常见导数-指数函数","formula":"(eˣ)' = eˣ, (aˣ)' = aˣlna","desc":"指数函数的导数公式","example":"(eˣ)' = eˣ, (2ˣ)' = 2ˣln2","category":"导数","scope":["高中"],"difficulty":3},
  {"id":"m075","name":"常见导数-对数函数","formula":"(lnx)' = 1/x, (logₐx)' = 1/(xlna)","desc":"对数函数的导数公式","example":"(lnx)' = 1/x, (lgx)' = 1/(xln10)","category":"导数","scope":["高中"],"difficulty":3},
  {"id":"m076","name":"常见导数-三角函数","formula":"(sinx)'=cosx, (cosx)'=-sinx, (tanx)'=sec²x","desc":"三角函数的导数公式","example":"(sinx)' = cosx","category":"导数","scope":["高中"],"difficulty":3},
  {"id":"m077","name":"导数四则运算","formula":"(f±g)'=f'±g', (fg)'=f'g+fg', (f/g)'=(f'g-fg')/g²","desc":"导数的加减乘除运算法则","example":"(x²sinx)' = 2xsinx + x²cosx","category":"导数","scope":["高中"],"difficulty":4},
  {"id":"m078","name":"复合函数求导","formula":"[f(g(x))]' = f'(g(x))·g'(x)","desc":"链式法则，外层导数乘以内层导数","example":"(sin2x)' = cos2x·2 = 2cos2x","category":"导数","scope":["高中"],"difficulty":4},
  {"id":"m079","name":"向量数量积","formula":"a·b = |a||b|cosθ = x₁x₂+y₁y₂","desc":"两个向量的数量积（点积）","example":"a=(1,2),b=(3,1)，a·b=3+2=5","category":"向量","scope":["高中"],"difficulty":3},
  {"id":"m080","name":"向量模","formula":"|a| = √(x²+y²)","desc":"向量的长度（模）","example":"a=(3,4)，|a|=√(9+16)=5","category":"向量","scope":["高中"],"difficulty":2},
  {"id":"m081","name":"向量夹角公式","formula":"cosθ = (a·b)/(|a||b|)","desc":"两向量夹角的余弦值","example":"a=(1,0),b=(1,1)，cosθ=1/(1×√2)=√2/2，θ=45°","category":"向量","scope":["高中"],"difficulty":3},
  {"id":"m082","name":"排列数公式","formula":"Aₙᵐ = n!/(n-m)!","desc":"从n个不同元素中取m个的排列数","example":"A₅² = 5!/3! = 20","category":"排列组合","scope":["高中"],"difficulty":3},
  {"id":"m083","name":"组合数公式","formula":"Cₙᵐ = n!/(m!(n-m)!)","desc":"从n个不同元素中取m个的组合数","example":"C₅² = 5!/(2!×3!) = 10","category":"排列组合","scope":["高中"],"difficulty":3},
  {"id":"m084","name":"二项式定理","formula":"(a+b)ⁿ = ΣCₙᵏaⁿ⁻ᵏbᵏ","desc":"二项展开式，通项为Cₙᵏaⁿ⁻ᵏbᵏ","example":"(x+1)³=C₃⁰x³+C₃¹x²+C₃²x+C₃³=x³+3x²+3x+1","category":"排列组合","scope":["高中"],"difficulty":4},
  {"id":"m085","name":"古典概型","formula":"P(A) = A包含的基本事件数/总基本事件数","desc":"等可能事件概率的计算","example":"掷骰子得偶数概率=3/6=1/2","category":"概率","scope":["高中"],"difficulty":2},
  {"id":"m086","name":"互斥事件概率","formula":"P(A∪B) = P(A)+P(B)","desc":"互斥事件至少一个发生的概率等于各自概率之和","example":"P(掷1或2)=1/6+1/6=1/3","category":"概率","scope":["高中"],"difficulty":2},
  {"id":"m087","name":"独立事件概率","formula":"P(AB) = P(A)·P(B)","desc":"独立事件同时发生的概率等于各自概率之积","example":"两次掷骰子都得6，P=1/6×1/6=1/36","category":"概率","scope":["高中"],"difficulty":2},
  {"id":"m088","name":"条件概率","formula":"P(B|A) = P(AB)/P(A)","desc":"在A发生条件下B发生的概率","example":"P(偶数|大于3)=P(4或6)/P(4,5,6)=2/6÷3/6=2/3","category":"概率","scope":["高中"],"difficulty":4},
  {"id":"m089","name":"期望公式","formula":"E(X) = Σxᵢpᵢ","desc":"离散型随机变量的数学期望","example":"骰子期望E=1×1/6+2×1/6+...+6×1/6=3.5","category":"概率","scope":["高中"],"difficulty":3},
  {"id":"m090","name":"方差公式","formula":"D(X) = E(X²)-[E(X)]²","desc":"衡量随机变量偏离期望的程度","example":"骰子D=E(X²)-3.5²=(1+4+9+16+25+36)/6-12.25≈2.92","category":"概率","scope":["高中"],"difficulty":4},
  {"id":"m091","name":"对数运算","formula":"logₐ(MN)=logₐM+logₐN, logₐ(M/N)=logₐM-logₐN","desc":"对数的乘除运算性质","example":"log₂8 = log₂(2×4) = log₂2+log₂4 = 1+2 = 3","category":"对数","scope":["高中"],"difficulty":3},
  {"id":"m092","name":"换底公式","formula":"logₐb = lnb/lna = lgb/lga","desc":"对数换底公式","example":"log₂8 = ln8/ln2 = 3","category":"对数","scope":["高中"],"difficulty":3},
  {"id":"m093","name":"均值不等式","formula":"(a+b)/2 ≥ √(ab) (a,b>0)","desc":"算术平均数不小于几何平均数，当且仅当a=b时取等号","example":"a=2,b=8，(2+8)/2=5 ≥ √16=4","category":"不等式","scope":["高中"],"difficulty":3},
  {"id":"m094","name":"圆柱体积","formula":"V = πr²h","desc":"圆柱体积等于底面积乘以高","example":"半径3高5，V=π×9×5=45π","category":"几何公式","scope":["高中"],"difficulty":2},
  {"id":"m095","name":"圆锥体积","formula":"V = πr²h/3","desc":"圆锥体积等于等底等高圆柱体积的三分之一","example":"半径3高5，V=π×9×5/3=15π","category":"几何公式","scope":["高中"],"difficulty":2},
  {"id":"m096","name":"球体积","formula":"V = 4πr³/3","desc":"球的体积公式","example":"半径3，V=4π×27/3=36π","category":"几何公式","scope":["高中"],"difficulty":2},
  {"id":"m097","name":"球表面积","formula":"S = 4πr²","desc":"球的表面积公式","example":"半径3，S=4π×9=36π","category":"几何公式","scope":["高中"],"difficulty":2},
  {"id":"m098","name":"圆台体积","formula":"V = πh(R²+Rr+r²)/3","desc":"圆台体积公式，R为下底半径，r为上底半径","example":"R=4,r=2,h=3，V=π×3×(16+8+4)/3=28π","category":"几何公式","scope":["高中"],"difficulty":3},
  {"id":"m099","name":"点到直线距离","formula":"d = |Ax₀+By₀+C|/√(A²+B²)","desc":"点P(x₀,y₀)到直线Ax+By+C=0的距离","example":"点(1,2)到直线3x+4y-5=0，d=|3+8-5|/5=6/5","category":"坐标公式","scope":["高中"],"difficulty":3},
  {"id":"m100","name":"两平行线距离","formula":"d = |C₁-C₂|/√(A²+B²)","desc":"两平行线Ax+By+C₁=0与Ax+By+C₂=0间的距离","example":"3x+4y-5=0与3x+4y+5=0，d=10/5=2","category":"坐标公式","scope":["高中"],"difficulty":3}
]
